-- Chức năng kéo thanh trượt (mobile friendly)
local dragging = false
local function updateRange(input)
    local relativeX = (input.Position.X - slider.AbsolutePosition.X) / slider.AbsoluteSize.X
    local newRange = math.clamp(math.floor(relativeX * 50), 10, 50)
    Settings.Range = newRange
    sliderFill.Size = UDim2.new(newRange / 50, 0, 1, 0)
    sliderLabel.Text = "Tầm đánh: " .. newRange
end

slider.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        updateRange(input)
    end
end)

slider.InputEnded:Connect(function()
    dragging = false
end)

game:GetService("UserInputService").TouchMoved:Connect(function(input)
    if dragging then
        updateRange(input)
    end
end)

