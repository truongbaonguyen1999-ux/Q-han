-- ========== KILL AURA CHO ĐIỆN THOẠI ==========
-- Tự động đánh người chơi gần nhất
-- Nút bật/tắt hiển thị trên màn hình

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local VirtualInput = game:GetService("VirtualInputManager")
local LocalPlayer = Players.LocalPlayer

-- Cài đặt
local Settings = {
    Enabled = false,
    Range = 30,
    AttackDelay = 0.03
}

-- Hàm tìm người chơi gần nhất
local function GetNearestPlayer()
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return nil end
    
    local nearest = nil
    local shortestDist = Settings.Range
    local myPos = character.HumanoidRootPart.Position
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local targetChar = player.Character
            if targetChar and targetChar:FindFirstChild("HumanoidRootPart") then
                local humanoid = targetChar:FindFirstChild("Humanoid")
                if humanoid and humanoid.Health > 0 then
                    local dist = (targetChar.HumanoidRootPart.Position - myPos).Magnitude
                    if dist < shortestDist then
                        shortestDist = dist
                        nearest = player
                    end
                end
            end
        end
    end
    return nearest
end

-- Hàm tấn công
local function Attack(targetPlayer)
    if not targetPlayer then return end
    local targetChar = targetPlayer.Character
    if not targetChar then return end
    
    -- Gửi sự kiện tấn công qua RemoteEvent
    for _, remote in pairs(ReplicatedStorage:GetChildren()) do
        if remote:IsA("RemoteEvent") then
            local remoteName = remote.Name:lower()
            if remoteName:find("attack") or remoteName:find("hit") or remoteName:find("damage") or remoteName:find("swing") then
                pcall(function()
                    remote:FireServer(targetChar)
                end)
            end
        end
    end
    
    -- Mô phỏng click màn hình (touch)
    pcall(function()
        VirtualInput:SendMouseButtonEvent(0, 0, 0, true, game, 0)
        task.wait(0.01)
        VirtualInput:SendMouseButtonEvent(0, 0, 0, false, game, 0)
    end)
end

-- Vòng lặp Kill Aura
coroutine.wrap(function()
    while true do
        if Settings.Enabled then
            local target = GetNearestPlayer()
            if target then
                Attack(target)
            end
        end
        task.wait(Settings.AttackDelay)
    end
end)()

