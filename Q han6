local draggingSlider = false
local function updateSlider(input)
    local relativeX = math.clamp((input.Position.X - slider.AbsolutePosition.X) / slider.AbsoluteSize.X, 0, 1)
    local newDist = math.floor(relativeX * 50)
    newDist = math.clamp(newDist, 5, 50)
    Settings.MaxDistance = newDist
    sliderFill.Size = UDim2.new(newDist / 50, 0, 1, 0)
    distLabel.Text = "Max Distance: " .. newDist .. " studs"
end
slider.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        draggingSlider = true
        updateSlider(input)
    end
end)
slider.InputEnded:Connect(function() draggingSlider = false end)
UserInputService.TouchMoved:Connect(function(input)
    if draggingSlider then updateSlider(input) end
end)

espBtn.MouseButton1Click:Connect(function()
    Settings.ShowESP = not Settings.ShowESP
    if Settings.ShowESP then
        espBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
        espBtn.Text = "Show Target ESP: ON"
        pcall(updateESP)
    else
        espBtn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
        espBtn.Text = "Show Target ESP: OFF"
        for _, obj in pairs(ESPObjects) do pcall(function() obj:Destroy() end) end
        ESPObjects = {}
    end
end)

-- Kéo thả menu
local menuDrag = false
local menuDragStart, menuStartPos
mainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        menuDrag = true
        menuDragStart = input.Position
        menuStartPos = mainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then menuDrag = false end
        end)
    end
end)
UserInputService.TouchMoved:Connect(function(input)
    if menuDrag then
        local delta = input.Position - menuDragStart
        mainFrame.Position = UDim2.new(menuStartPos.X.Scale, menuStartPos.X.Offset + delta.X, menuStartPos.Y.Scale, menuStartPos.Y.Offset + delta.Y)
    end
end)

