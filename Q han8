-- ========== VAMPIRE HELPER - BẢN CHUẨN NHẤT (PHÂN BIỆT PHE CHẮC CHẮN) ==========
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = Players.LocalPlayer
local UserInputService = game:GetService("UserInputService")

-- Cài đặt
local Settings = {
    Enabled = false,
    MaxDistance = 100,
    ShowESP = false,
    AttackDelay = 0.02,
    TargetMode = "Enemy"  -- Enemy / Friend / All
}

-- Tìm remote tấn công
local AttackRemotes = {}
for _, remote in pairs(ReplicatedStorage:GetDescendants()) do
    if remote:IsA("RemoteEvent") then
        table.insert(AttackRemotes, remote)
    end
end
print("[VH] Tìm thấy " .. #AttackRemotes .. " remote")

-- ========== PHÂN BIỆT PHE CHUẨN XÁC ==========
local function IsEnemy(player)
    if player == LocalPlayer then return false end
    
    -- Lấy team của bạn và team của mục tiêu
    local myTeam = LocalPlayer.Team
    local theirTeam = player.Team
    
    -- Nếu cả 2 đều có team
    if myTeam and theirTeam then
        return myTeam ~= theirTeam  -- Khác team = kẻ địch
    end
    
    -- Nếu game dùng tên team (Human / Vampire)
    if theirTeam and theirTeam.Name then
        local teamName = theirTeam.Name:lower()
        if teamName:find("human") or teamName:find("survivor") then
            return true   -- Human là kẻ địch (nếu bạn là Vamp)
        elseif teamName:find("vamp") or teamName:find("vampire") then
            return false  -- Vamp là đồng đội
        end
    end
    
    -- Mặc định: nếu không xác định được, coi là kẻ địch (để an toàn)
    return true
end

-- Hàm lọc theo chế độ
local function ShouldAttack(player)
    if Settings.TargetMode == "Enemy" then
        return IsEnemy(player)
    elseif Settings.TargetMode == "Friend" then
        return not IsEnemy(player) and player ~= LocalPlayer
    else  -- All
        return player ~= LocalPlayer
    end
end

-- ========== TÌM MỤC TIÊU ==========
local function GetNearestTarget()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    
    local nearest, minDist = nil, Settings.MaxDistance
    local myPos = char.HumanoidRootPart.Position
    
    for _, plr in pairs(Players:GetPlayers()) do
        if ShouldAttack(plr) then
            local tChar = plr.Character
            if tChar and tChar:FindFirstChild("HumanoidRootPart") then
                local hum = tChar:FindFirstChild("Humanoid")
                if hum and hum.Health > 0 then
                    local dist = (tChar.HumanoidRootPart.Position - myPos).Magnitude
                    if dist < minDist then
                        minDist, nearest = dist, plr
                    end
                end
            end
        end
    end
    return nearest
end

-- ========== TẤN CÔNG (KHÔNG DỊCH CHUYỂN) ==========
local function AttackTarget(target)
    if not target or not target.Character then return end
    local targetChar = target.Character
    if not targetChar then return end
    
    for _, remote in ipairs(AttackRemotes) do
        pcall(function() remote:FireServer(targetChar) end)
    end
    
    local myChar = LocalPlayer.Character
    if myChar then
        for _, tool in pairs(myChar:GetChildren()) do
            if tool:IsA("Tool") then
                pcall(function() tool:Activate() end)
            end
        end
    end
end

-- Vòng lặp chính
coroutine.wrap(function()
    while true do
        if Settings.Enabled then
            local target = GetNearestTarget()
            if target then
                AttackTarget(target)
            end
        end
        task.wait(Settings.AttackDelay)
    end
end)()

-- ========== ESP ==========
local ESPObjects = {}
local function UpdateESP()
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            local char = plr.Character
            if char and char:FindFirstChild("HumanoidRootPart") and Settings.ShowESP then
                if not ESPObjects[plr] then
                    local box = Instance.new("BoxHandleAdornment")
                    box.Size = Vector3.new(4, 5, 2)
                    if IsEnemy(plr) then
                        box.Color3 = Color3.fromRGB(255, 50, 50)  -- Đỏ = kẻ địch
                    else
                        box.Color3 = Color3.fromRGB(50, 255, 50)  -- Xanh = đồng đội
                    end
                    box.Transparency = 0.5
                    box.AlwaysOnTop = true
                    box.Adornee = char.HumanoidRootPart
                    box.Parent = char
                    ESPObjects[plr] = box
                end
            elseif ESPObjects[plr] then
                ESPObjects[plr]:Destroy()
                ESPObjects[plr] = nil
            end
        end
    end
end

coroutine.wrap(function()
    while true do
        if Settings.ShowESP then pcall(UpdateESP) end
        task.wait(0.3)
    end
end)()

