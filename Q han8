-- Thanh trượt
local dragging = false
local function updateSlider(input)
    local relX = math.clamp((input.Position.X - slider.AbsolutePosition.X) / slider.AbsoluteSize.X, 0, 1)
    local newDist = math.floor(relX * 150)
    newDist = math.clamp(newDist, 20, 150)
    Settings.MaxDistance = newDist
    sliderFill.Size = UDim2.new(newDist / 150, 0, 1, 0)
    distLabel.Text = "📏 Tầm đánh: " .. newDist
end
slider.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        updateSlider(input)
    end
end)
slider.InputEnded:Connect(function() dragging = false end)
UserInputService.TouchMoved:Connect(function(input)
    if dragging then updateSlider(input) end
end)

espBtn.MouseButton1Click:Connect(function()
    Settings.ShowESP = not Settings.ShowESP
    if Settings.ShowESP then
        espBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
        espBtn.Text = "👁️ ESP: ON"
        UpdateESP()
    else
        espBtn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
        espBtn.Text = "👁️ ESP: OFF"
        for _, obj in pairs(ESPObjects) do obj:Destroy() end
        table.clear(ESPObjects)
    end
end)

