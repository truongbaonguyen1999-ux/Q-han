-- ========== KILL AURA XUYÊN TƯỜNG - KHÔNG XOAY NGƯỜI ==========
-- Dành cho điện thoại, vẫn di chuyển bình thường
-- Bỏ Silent Aim: nhân vật KHÔNG tự động quay lại khi đánh

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local VirtualInput = game:GetService("VirtualInputManager")
local LocalPlayer = Players.LocalPlayer

-- ========== CÀI ĐẶT ==========
local Settings = {
    Enabled = false,
    Range = 60,        -- Tầm đánh xa (xuyên tường)
    AttackDelay = 0.02 -- Tốc độ spam cực nhanh
}

-- ========== TÌM MỤC TIÊU GẦN NHẤT (BỎ QUA TƯỜNG) ==========
local function GetNearestPlayer()
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return nil end
    
    local nearest = nil
    local shortestDist = Settings.Range
    local myPos = character.HumanoidRootPart.Position
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local targetChar = player.Character
            if targetChar and targetChar:FindFirstChild("HumanoidRootPart") then
                local humanoid = targetChar:FindFirstChild("Humanoid")
                if humanoid and humanoid.Health > 0 then
                    -- Tính khoảng cách xuyên tường (ko cần raycast)
                    local dist = (targetChar.HumanoidRootPart.Position - myPos).Magnitude
                    if dist < shortestDist then
                        shortestDist = dist
                        nearest = player
                    end
                end
            end
        end
    end
    return nearest
end

-- ========== HÀM TẤN CÔNG (KHÔNG XOAY NGƯỜI) ==========
local function Attack(targetPlayer)
    if not targetPlayer then return end
    local targetChar = targetPlayer.Character
    if not targetChar or not targetChar:FindFirstChild("HumanoidRootPart") then return end
    
    -- ====== KHÔNG CÓ SILENT AIM ======
    -- Nhân vật GIỮ NGUYÊN HƯỚNG, không tự động quay
    
    -- Gửi sự kiện tấn công qua RemoteEvent
    for _, remote in pairs(ReplicatedStorage:GetChildren()) do
        if remote:IsA("RemoteEvent") then
            local remoteName = remote.Name:lower()
            if remoteName:find("attack") or remoteName:find("hit") or remoteName:find("damage") or remoteName:find("swing") or remoteName:find("melee") then
                pcall(function()
                    remote:FireServer(targetChar)
                end)
            end
        end
    end
    
    -- Gửi sự kiện từ Tool (vũ khí đang cầm)
    local character = LocalPlayer.Character
    if character then
        for _, tool in pairs(character:GetChildren()) do
            if tool:IsA("Tool") then
                -- Kích hoạt tool (cầm kiếm/gậy)
                pcall(function()
                    tool:Activate()
                end)
                
                -- Gửi remote từ tool
                for _, remote in pairs(tool:GetChildren()) do
                    if remote:IsA("RemoteEvent") then
                        pcall(function()
                            remote:FireServer(targetChar)
                        end)
                    end
                end
            end
        end
    end
    
    -- Mô phỏng click chuột/touch (spam đánh thường)
    pcall(function()
        VirtualInput:SendMouseButtonEvent(0, 0, 0, true, game, 0)
        task.wait(0.005)
        VirtualInput:SendMouseButtonEvent(0, 0, 0, false, game, 0)
    end)
end

-- ========== VÒNG LẶP SPAM ĐÁNH ==========
coroutine.wrap(function()
    while true do
        if Settings.Enabled then
            local target = GetNearestPlayer()
            if target then
                Attack(target)
            end
        end
        task.wait(Settings.AttackDelay)
    end
end)()

