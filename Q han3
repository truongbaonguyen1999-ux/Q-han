    UpdateButton()
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "DeltaVN",
        Text = Settings.Enabled and "✅ KILL AURA BẬT (Xuyên tường - Không xoay người)" or "❌ ĐÃ TẮT",
        Duration = 1
    })
end)

-- ========== THANH TRƯỢT ĐIỀU CHỈNH TẦM ĐÁNH ==========
local sliderFrame = Instance.new("Frame")
sliderFrame.Size = UDim2.new(0, 220, 0, 90)
sliderFrame.Position = UDim2.new(0.02, 0, 0.75, 0)
sliderFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
sliderFrame.BackgroundTransparency = 0.2
sliderFrame.BorderSizePixel = 0
sliderFrame.Parent = screenGui

local sliderCorner = Instance.new("UICorner")
sliderCorner.CornerRadius = UDim.new(0, 12)
sliderCorner.Parent = sliderFrame

local sliderLabel = Instance.new("TextLabel")
sliderLabel.Size = UDim2.new(1, 0, 0.4, 0)
sliderLabel.Position = UDim2.new(0, 0, 0, 0)
sliderLabel.BackgroundTransparency = 1
sliderLabel.Text = "🎯 Tầm đánh: " .. Settings.Range
sliderLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
sliderLabel.TextScaled = true
sliderLabel.Font = Enum.Font.GothamBold
sliderLabel.Parent = sliderFrame

local slider = Instance.new("Frame")
slider.Size = UDim2.new(0.9, 0, 0.25, 0)
slider.Position = UDim2.new(0.05, 0, 0.55, 0)
slider.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
slider.BorderSizePixel = 0
slider.Parent = sliderFrame

local sliderFill = Instance.new("Frame")
sliderFill.Size = UDim2.new(Settings.Range / 100, 0, 1, 0)
sliderFill.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
sliderFill.BorderSizePixel = 0
sliderFill.Parent = slider

local sliderCorner2 = Instance.new("UICorner")
sliderCorner2.CornerRadius = UDim.new(1, 0)
sliderCorner2.Parent = sliderFill

local dragging = false
local function updateRange(input)
    local relativeX = (input.Position.X - slider.AbsolutePosition.X) / slider.AbsoluteSize.X
    local newRange = math.clamp(math.floor(relativeX * 100), 15, 100)
    Settings.Range = newRange
    sliderFill.Size = UDim2.new(newRange / 100, 0, 1, 0)
    sliderLabel.Text = "🎯 Tầm đánh: " .. newRange .. " (Xuyên tường)"
end

slider.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        updateRange(input)
    end
end)

slider.InputEnded:Connect(function()
    dragging = false
end)

game:GetService("UserInputService").TouchMoved:Connect(function(input)
    if dragging then
        updateRange(input)
    end
end)

-- ========== NÚT ĐIỀU CHỈNH TỐC ĐỘ (TÙY CHỌN) ==========
local speedFrame = Instance.new("Frame")
speedFrame.Size = UDim2.new(0, 220, 0, 80)
speedFrame.Position = UDim2.new(0.02, 0, 0.88, 0)
speedFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
speedFrame.BackgroundTransparency = 0.2
speedFrame.BorderSizePixel = 0
speedFrame.Parent = screenGui

local speedCorner = Instance.new("UICorner")
speedCorner.CornerRadius = UDim.new(0, 12)
speedCorner.Parent = speedFrame

local speedLabel = Instance.new("TextLabel")
speedLabel.Size = UDim2.new(1, 0, 0.4, 0)
speedLabel.Position = UDim2.new(0, 0, 0, 0)
speedLabel.BackgroundTransparency = 1
speedLabel.Text = "⚡ Tốc độ: " .. math.floor(Settings.AttackDelay * 1000) .. "ms"
speedLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
speedLabel.TextScaled = true
speedLabel.Font = Enum.Font.GothamBold
speedLabel.Parent = speedFrame

local speedSlider = Instance.new("Frame")
speedSlider.Size = UDim2.new(0.9, 0, 0.25, 0)
speedSlider.Position = UDim2.new(0.05, 0, 0.55, 0)
speedSlider.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
speedSlider.BorderSizePixel = 0
speedSlider.Parent = speedFrame

local speedFill = Instance.new("Frame")
local minDelay = 5   -- 5ms nhanh nhất
local maxDelay = 80  -- 80ms chậm nhất
local delayRange = maxDelay - minDelay
local currentDelayValue = math.clamp(Settings.AttackDelay * 1000, minDelay, maxDelay)
speedFill.Size = UDim2.new((currentDelayValue - minDelay) / delayRange, 0, 1, 0)
speedFill.BackgroundColor3 = Color3.fromRGB(255, 150, 0)
speedFill.BorderSizePixel = 0
speedFill.Parent = speedSlider

local speedCorner2 = Instance.new("UICorner")
speedCorner2.CornerRadius = UDim.new(1, 0)
speedCorner2.Parent = speedFill

local speedDragging = false
local function updateSpeed(input)
    local relativeX = (input.Position.X - speedSlider.AbsolutePosition.X) / speedSlider.AbsoluteSize.X
    local delayMs = math.clamp(minDelay + relativeX * delayRange, minDelay, maxDelay)
    Settings.AttackDelay = delayMs / 1000
    speedFill.Size = UDim2.new((delayMs - minDelay) / delayRange, 0, 1, 0)
    speedLabel.Text = "⚡ Tốc độ: " .. math.floor(delayMs) .. "ms"
end

speedSlider.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        speedDragging = true
        updateSpeed(input)
    end
end)

speedSlider.InputEnded:Connect(function()
    speedDragging = false
end)

game:GetService("UserInputService").TouchMoved:Connect(function(input)
    if speedDragging then
        updateSpeed(input)
    end
end)

