-- Chỉ đánh Human (kẻ địch), đứng xa vẫn trúng, ESP màu đỏ cho Human

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = Players.LocalPlayer
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

-- Cài đặt
local Settings = {
    AutoPunch = false,
    MaxDistance = 120,
    ShowESP = false,
    PunchDelay = 0.015
}

-- Tìm remote tấn công
local AttackRemotes = {}
local function findRemotes()
    for _, remote in pairs(ReplicatedStorage:GetDescendants()) do
        if remote:IsA("RemoteEvent") then
            local name = remote.Name:lower()
            if name:find("punch") or name:find("attack") or name:find("hit") or name:find("damage") or name:find("melee") then
                table.insert(AttackRemotes, remote)
            end
        end
    end
    if #AttackRemotes == 0 then
        for _, remote in pairs(ReplicatedStorage:GetDescendants()) do
            if remote:IsA("RemoteEvent") then table.insert(AttackRemotes, remote) end
        end
    end
    print("[Helper] Tìm thấy " .. #AttackRemotes .. " remote")
end
pcall(findRemotes)

-- ========== PHÂN BIỆT PHE (QUAN TRỌNG NHẤT) ==========
local function IsEnemy(player)
    -- Nếu là chính mình -> không phải kẻ địch
    if player == LocalPlayer then return false end
    
    local myTeam = LocalPlayer.Team
    local theirTeam = player.Team
    
    -- Cách 1: Dựa vào Team (nếu game có)
    if myTeam and theirTeam then
        if myTeam ~= theirTeam then
            return true  -- Khác team = kẻ địch
        else
            return false -- Cùng team = đồng đội
        end
    end
    
    -- Cách 2: Dựa vào tên đội (Human / Vampire)
    if theirTeam then
        local teamName = theirTeam.Name:lower()
        if teamName:find("human") or teamName:find("humanoid") or teamName:find("survivor") then
            return true  -- Human = kẻ địch
        else
            return false -- Vampire = đồng đội
        end
    end
    
    -- Cách 3: Dựa vào màu sắc của đội (nếu có)
    if theirTeam and theirTeam.TeamColor then
        local color = theirTeam.TeamColor.Name:lower()
        -- Human thường màu xanh lá, xanh dương; Vampire màu đỏ, tím
        if color:find("blue") or color:find("green") or color:find("yellow") then
            return true  -- Màu sáng = Human (tạm coi là kẻ địch)
        else
            return false -- Màu tối = Vampire
        end
    end
    
    -- Cách 4: Dựa vào tên nhân vật hoặc attribute
    local character = player.Character
    if character then
        if character:GetAttribute("Team") then
            local attr = character:GetAttribute("Team"):lower()
            if attr:find("human") then return true
            else return false end
        end
    end
    
    -- Mặc định: nếu không xác định được, coi là kẻ địch (để an toàn)
    return true
end

-- ========== ESP (Đỏ = Kẻ địch / Human, Xanh = Đồng đội / Vampire) ==========
local ESPObjects = {}
local function updateESP()
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            local char = plr.Character
            if char and char:FindFirstChild("HumanoidRootPart") and Settings.ShowESP then
                if not ESPObjects[plr] then
                    local box = Instance.new("BoxHandleAdornment")
                    box.Size = Vector3.new(4, 5, 2)
                    -- Phân biệt màu theo phe
                    if IsEnemy(plr) then
                        box.Color3 = Color3.fromRGB(255, 0, 0)   -- ĐỎ = Kẻ địch (Human)
                    else
                        box.Color3 = Color3.fromRGB(0, 255, 0)   -- XANH = Đồng đội (Vampire)
                    end
                    box.Transparency = 0.4
                    box.AlwaysOnTop = true
                    box.Adornee = char.HumanoidRootPart
                    box.Parent = char
                    ESPObjects[plr] = box
                else
                    -- Cập nhật màu nếu cần
                    if IsEnemy(plr) then
                        ESPObjects[plr].Color3 = Color3.fromRGB(255, 0, 0)
                    else
                        ESPObjects[plr].Color3 = Color3.fromRGB(0, 255, 0)
                    end
                end
            elseif ESPObjects[plr] then
                ESPObjects[plr]:Destroy()
                ESPObjects[plr] = nil
            end
        end
    end
end

-- Cập nhật ESP định kỳ
coroutine.wrap(function()
    while true do
        if Settings.ShowESP then
            pcall(updateESP)
        end
        task.wait(0.3)
    end
end)()

-- ========== TÌM KẺ ĐỊCH GẦN NHẤT (CHỈ HUMAN) ==========
local function GetNearestEnemy()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    
    local nearest = nil
    local minDist = Settings.MaxDistance
    local myPos = char.HumanoidRootPart.Position
    
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and IsEnemy(plr) then  -- CHỈ LẤY KẺ ĐỊCH
            local tChar = plr.Character
            if tChar and tChar:FindFirstChild("HumanoidRootPart") then
                local hum = tChar:FindFirstChild("Humanoid")
                if hum and hum.Health > 0 then
                    local dist = (tChar.HumanoidRootPart.Position - myPos).Magnitude
                    if dist < minDist then
                        minDist = dist
                        nearest = plr
                    end
                end
            end
        end
    end
    return nearest, minDist
end

-- ========== TẤN CÔNG TỪ XA (KHÔNG DỊCH CHUYỂN) ==========
local function AttackEnemyFromDistance(target)
    if not target or not target.Character then return end
    local targetChar = target.Character
    if not targetChar or not targetChar:FindFirstChild("HumanoidRootPart") then return end
    
    -- Gửi remote event (không cần teleport)
    for _, remote in ipairs(AttackRemotes) do
        pcall(function() remote:FireServer(targetChar) end)
    end
    
    -- Kích hoạt tool hiện tại (vũ khí)
    local myChar = LocalPlayer.Character
    if myChar then
        for _, tool in pairs(myChar:GetChildren()) do
            if tool:IsA("Tool") then
                pcall(function() tool:Activate() end)
            end
        end
    end
end

-- Vòng lặp chính (tốc độ cao, không teleport)
coroutine.wrap(function()
    while true do
        if Settings.AutoPunch then
            local target = GetNearestEnemy()
            if target then
                pcall(AttackEnemyFromDistance, target)
            end
        end
        task.wait(Settings.PunchDelay)
    end
end)()

